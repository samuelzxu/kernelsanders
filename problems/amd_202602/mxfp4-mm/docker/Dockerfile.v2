# Use pre-built ROCm dev image to avoid install failures
FROM rocm/dev-ubuntu-24.04:7.1-complete

RUN apt-get update && apt-get install -y python3-pip python3-dev && rm -rf /var/lib/apt/lists/*
RUN pip install --break-system-packages torch==2.10.0+rocm7.1 --index-url https://download.pytorch.org/whl/rocm7.1 || true

WORKDIR /workspace
